# ─── Perplexity API ───────────────────────────────────
PERPLEXITY_API_KEY=your_key_here
PERPLEXITY_MODEL=sonar-pro            # sonar-pro for quality, sonar for cheaper tasks

# ─── Supabase ─────────────────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here

# ─── GitHub (for automated commits from CI) ──────────
GITHUB_TOKEN=your_github_token_here

# ─── Run Configuration ────────────────────────────────
DRY_RUN=false                         # true = print actions without writing files or calling APIs
FORCE_REGENERATE=false                # true = skip all cache guards, regenerate everything
MAX_PRE_EARNINGS_DAYS=14              # generate pre-note up to N days before earnings
MAX_POST_EARNINGS_DAYS=14             # keep post-note active for N days after earnings
